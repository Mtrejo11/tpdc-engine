{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tpdc/capabilities/execute/output",
  "title": "ExecutionArtifact",
  "description": "Output for execute capability — execution report with per-step results.",
  "type": "object",
  "required": ["sourceTicket", "planTitle", "status", "appliedChangesSummary", "touchedArtifacts", "evidence", "stepResults"],
  "properties": {
    "sourceTicket": { "type": "string", "minLength": 1 },
    "planTitle": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["completed", "partial", "failed", "blocked"] },
    "appliedChangesSummary": { "type": "string", "minLength": 1 },
    "touchedArtifacts": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "evidence": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "stepResults": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["stepNumber", "title", "status", "changeSummary", "evidence"],
        "properties": {
          "stepNumber": { "type": "integer", "minimum": 1 },
          "title": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["completed", "partial", "skipped", "blocked"] },
          "changeSummary": { "type": "string", "minLength": 1 },
          "touchedArtifacts": { "type": "array", "items": { "type": "string" } },
          "evidence": { "type": "string", "minLength": 1 },
          "blockedReason": { "type": "string" }
        }
      }
    },
    "notes": { "type": "string" }
  }
}
