{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tpdc/capabilities/decompose/output",
  "title": "PlanArtifact",
  "description": "Output for decompose capability — an execution plan or blocked declaration.",
  "type": "object",
  "required": ["sourceTicket", "designTitle", "status"],
  "properties": {
    "sourceTicket": { "type": "string", "minLength": 1 },
    "designTitle": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["actionable", "blocked"] },
    "blockedReason": { "type": "string", "minLength": 1 },
    "unresolvedQuestions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["question", "owner"],
        "properties": {
          "question": { "type": "string", "minLength": 1 },
          "owner": { "type": "string", "minLength": 1 }
        }
      }
    },
    "changeStrategy": { "type": "string", "minLength": 1 },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["risk", "trigger"],
        "properties": {
          "risk": { "type": "string", "minLength": 1 },
          "trigger": { "type": "string", "minLength": 1 }
        }
      }
    },
    "validationPlan": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["ac", "verification"],
        "properties": {
          "ac": { "type": "string", "minLength": 1 },
          "verification": { "type": "string", "minLength": 1 }
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["stepNumber", "title", "goal", "surface", "executionContext", "stackAssumption", "description", "acceptanceCriteria"],
        "properties": {
          "stepNumber": { "type": "integer", "minimum": 1 },
          "title": { "type": "string", "minLength": 1 },
          "goal": { "type": "string", "minLength": 1 },
          "surface": { "type": "string", "enum": ["web_ui", "mobile_ui", "api_endpoint", "background_job", "report", "admin_tool", "not_applicable", "unknown"] },
          "executionContext": { "type": "string", "enum": ["frontend", "backend", "database", "external_service", "infra", "not_applicable", "unknown"] },
          "stackAssumption": { "type": "string", "enum": ["none", "react", "next", "react_native", "expo", "python", "mixed", "not_applicable", "unknown"] },
          "description": { "type": "string", "minLength": 1 },
          "dependencies": { "type": "array", "items": { "type": "integer" } },
          "acceptanceCriteria": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
