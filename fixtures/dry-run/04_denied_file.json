{
  "description": "Denied file target — .env and package-lock.json are in the deny list",
  "patches": [
    {
      "filePath": ".env",
      "operation": "create",
      "diff": "--- /dev/null\n+++ b/.env\n@@ -0,0 +1,2 @@\n+API_KEY=sk-secret-key-12345\n+DATABASE_URL=postgres://localhost/mydb\n"
    },
    {
      "filePath": "package-lock.json",
      "operation": "modify",
      "diff": "--- a/package-lock.json\n+++ b/package-lock.json\n@@ -1,3 +1,3 @@\n {\n-  \"lockfileVersion\": 3,\n+  \"lockfileVersion\": 4,\n }\n"
    }
  ]
}
